<!DOCTYPE html>
<html>

<head>
	<meta charset="UTF-8">
	<title>Travel - Travlr Getaways Web Template</title>
	<link rel="stylesheet" href="/css/style.css" type="text/css">
</head>

<body>
	<div id="background">
		<div id="page">
			{{> header }}
			<div id="contents">
				<div class="box">
					<div>
						<div class="body">
							<h1>Travel</h1>
							<ul id="sites" style="list-style: none; padding: 0;">
								{{#each trips}}
								<li style="padding-bottom: 12px; margin-bottom: 12px;">
									<table style="border-collapse: collapse;">
										<tr>
											<td style="vertical-align: top; padding-right: 20px; width: 220px;">
												<div style="width: 220px;">
													<a href="/api/trips/{{this.code}}">
														<img src="/images/{{this.image}}" alt="{{this.name}}"
															width="220px" style="display: block;">
													</a>
												</div>
											</td>
											<td style="vertical-align: top;">
												<h2 style="margin: 0 0 8px 0;"><a href="/travel">{{this.name}}</a></h2>
												<button style="display: block; width: 100px;"
													onclick="bookTrip('{{this._id}}')">Book Trip</button>
												<p>{{{this.description}}}</p>
												<table>
													<tr>
														<td><strong>Resort</strong></td>
														<td>{{this.resort}}</td>
													</tr>
													<tr>
														<td><strong>Start Date</strong></td>
														<td class="start-date">{{this.start}}</td>
													</tr>
													<tr>
														<td><strong>Length</strong></td>
														<td>{{this.lengthInDays}} days</td>
													</tr>
													<tr>
														<td><strong>Price</strong></td>
														<td>${{this.price}} per person</td>
													</tr>
													<tr>
														<td><strong>Climate</strong></td>
														<td>{{this.tags.climate}}</td>
													</tr>
													<tr>
														<td><strong>Activity</strong></td>
														<td>{{this.tags.activityType}}</td>
													</tr>
													<tr>
														<td><strong>Budget</strong></td>
														<td>{{this.tags.budgetRange}}</td>
													</tr>
													<tr>
														<td><strong>Duration</strong></td>
														<td>{{this.tags.tripDuration}}</td>
													</tr>
												</table>
											</td>
										</tr>
									</table>
								</li>
								{{/each}}
							</ul>
						</div>
					</div>
				</div>
			</div>
		</div>
		{{> footer }}
	</div>

	<script>
		document.querySelectorAll('.start-date').forEach(el => {
			const date = new Date(el.textContent);
			el.textContent = date.toLocaleDateString('en-US', {
				year: 'numeric',
				month: 'long',
				day: 'numeric'
			});
		});

		function bookTrip(tripId) {
			const token = localStorage.getItem('travlr-token');
			if (!token) {
				alert('You must be logged in to book a trip.');
				return;
			}

			const travelDate = prompt('Enter your travel date (YYYY-MM-DD):');
			if (!travelDate) return;

			fetch('/api/bookings', {
				method: 'POST',
				headers: {
					'Content-Type': 'application/json',
					'Authorization': `Bearer ${token}`
				},
				body: JSON.stringify({ tripId, travelDate })
			})
				.then(res => res.json())
				.then(data => {
					if (data._id) {
						alert('Booking confirmed!');
					} else {
						alert(data.message || 'Booking failed.');
					}
				})
				.catch(err => {
					console.error(err);
					alert('Something went wrong. Please try again.');
				});
		}
	</script>
</body>

</html>