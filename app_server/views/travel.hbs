<!DOCTYPE html>
<html>

<head>
	<meta charset="UTF-8">
	<title>Travel - Travlr Getaways Web Template</title>
	<link rel="stylesheet" href="/css/style.css" type="text/css">
</head>

<body>
	<div id="background">
		<div id="page">
			{{> header }}
			<div id="contents">
				<div class="box">
					<div>
						<div class="body">
							<h1>Travel</h1>
							<ul id="sites">
								{{#each trips}}
								<li>
									<button onclick="bookTrip('{{this._id}}')">Book Trip</button>
									<a href="/api/trips/{{this.code}}"><img src="/images/{{this.image}}" alt="Img"></a>
									<h2><a href="/travel">{{this.name}}</a></h2>
									<p>{{{this.description}}}</p>
								</li>
								{{/each}}
							</ul>
						</div>
					</div>
				</div>
			</div>
		</div>
		{{> footer }}
	</div>

	<script>
		function bookTrip(tripId) {
			const token = localStorage.getItem('travlr-token');
			if (!token) {
				alert('You must be logged in to book a trip.');
				return;
			}

			const travelDate = prompt('Enter your travel date (YYYY-MM-DD):');
			if (!travelDate) return;

			fetch('/api/bookings', {
				method: 'POST',
				headers: {
					'Content-Type': 'application/json',
					'Authorization': `Bearer ${token}`
				},
				body: JSON.stringify({ tripId, travelDate })
			})
				.then(res => res.json())
				.then(data => {
					if (data._id) {
						alert('Booking confirmed!');
					} else {
						alert(data.message || 'Booking failed.');
					}
				})
				.catch(err => {
					console.error(err);
					alert('Something went wrong. Please try again.');
				});
		}
	</script>
</body>

</html>