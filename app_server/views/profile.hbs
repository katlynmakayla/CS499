<!DOCTYPE html>
<!-- Website template by freewebsitetemplates.com -->
<html>

<head>
    <meta charset="UTF-8">
    <title>Profile - Travlr Getaways Web Template</title>
    <link rel="stylesheet" href="/css/style.css" type="text/css">
</head>

<body>
    <div id="background">
        <div id="page">
            {{> header }}
            <div id="contents">
                <div class="box">
                    <div>
                        <div class="body">
                            <div class="row">
                                <div class="col-12 col-md-8">
                                    <h1>My Travel Profile</h1>
                                    <p class="mb-4">Customize your preferences to get better vacation recommendations.</p>

                                    <div id="status-alert" role="alert" class="alert" style="display: none;">
                                        <span id="status-message"></span>
                                    </div>

                                    <form id="profile-form">

                                        <div class="form-group mb-3">
                                            <label for="budgetRange" class="form-label">Preferred Budget Range</label>
                                            <select id="budgetRange" name="budgetRange" class="form-control">
                                                <option value="budget">Budget</option>
                                                <option value="midrange">Mid-range</option>
                                                <option value="luxury">Luxury</option>
                                            </select>
                                        </div>

                                        <div class="form-group mb-3">
                                            <label for="climate" class="form-label">Preferred Climate</label>
                                            <select id="climate" name="climate" class="form-control">
                                                <option value="tropical">Tropical</option>
                                                <option value="cold">Cold/Snowy</option>
                                                <option value="dry">Desert/Arid</option>
                                                <option value="temperate">Mild/Temperate</option>
                                            </select>
                                        </div>

                                        <div class="form-group mb-3">
                                            <label for="activityType" class="form-label">Favorite Activity</label>
                                            <select id="activityType" name="activityType" class="form-control">
                                                <option value="adventure">Adventure</option>
                                                <option value="relaxation">Relaxation</option>
                                                <option value="cultural">Cultural/Historic</option>
                                            </select>
                                        </div>

                                        <div class="form-group mb-4">
                                            <label for="tripDuration" class="form-label">Preferred Trip Duration</label>
                                            <select id="tripDuration" name="tripDuration" class="form-control">
                                                <option value="weekend">Weekend (1–3 days)</option>
                                                <option value="week">Week (4–7 days)</option>
                                                <option value="extended">Extended (8+ days)</option>
                                            </select>
                                        </div>

                                        <button type="submit" class="btn btn-primary">Save Preferences</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {{> footer }}
    </div>

    <script>
        const token = localStorage.getItem('travlr-token');
        const statusAlert = document.getElementById('status-alert');
        const statusMsg = document.getElementById('status-message');

        async function loadProfile() {
            if (!token) {
                window.location.href = '/login';
                return;
            }

            try {
                const response = await fetch('/api/user', {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                const user = await response.json();

                if (user.profile) {
                    if (user.profile.budgetRange)  document.getElementById('budgetRange').value  = user.profile.budgetRange;
                    if (user.profile.climate)      document.getElementById('climate').value      = user.profile.climate;
                    if (user.profile.activityType) document.getElementById('activityType').value = user.profile.activityType;
                    if (user.profile.tripDuration) document.getElementById('tripDuration').value = user.profile.tripDuration;
                }
            } catch (err) {
                console.error('Error fetching profile:', err);
            }
        }

        document.getElementById('profile-form').addEventListener('submit', async (e) => {
            e.preventDefault();

            const profileData = {
                budgetRange:  document.getElementById('budgetRange').value,
                climate:      document.getElementById('climate').value,
                activityType: document.getElementById('activityType').value,
                tripDuration: document.getElementById('tripDuration').value
            };

            try {
                const response = await fetch('/api/user/profile', {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify(profileData)
                });

                if (response.ok) {
                    showStatus('Preferences updated successfully!', 'alert-success');
                } else {
                    showStatus('Failed to update profile.', 'alert-danger');
                }
            } catch (err) {
                showStatus('Network error, please try again.', 'alert-danger');
            }
        });

        function showStatus(message, type) {
            statusMsg.innerText = message;
            statusAlert.className = `alert ${type}`;
            statusAlert.style.display = 'block';
            setTimeout(() => { statusAlert.style.display = 'none'; }, 3000);
        }

        loadProfile();
    </script>
</body>

</html>