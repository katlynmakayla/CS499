<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <title>Recommendations - Travlr Getaways Web Template</title>
    <link rel="stylesheet" href="/css/style.css" type="text/css">
    <style>
        .recommendation-item {
            padding-bottom: 12px;
            margin-bottom: 12px;
        }
    </style>
</head>

<body>
    <div id="background">
        <div id="page">
            {{> header }}
            <div id="contents">
                <div class="box">
                    <div>
                        <div class="body">
                            <h1>Personalized Recommendations</h1>
                            <p>Based on your profile settings, we've found these perfect getaways for you:</p>
                            <div id="recs-list" class="section">
                                <p id="loading-msg">Finding your perfect vacation...</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {{> footer }}
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const token = localStorage.getItem('travlr-token');

            const recsLink = document.getElementById('nav-recs');
            const loginLink = document.getElementById('nav-login');
            const logoutLink = document.getElementById('nav-logout');

            if (token && token !== 'null' && token !== 'undefined') {
                if (recsLink) recsLink.style.display = 'inline-block';
                if (logoutLink) logoutLink.style.display = 'inline-block';
                if (loginLink) loginLink.style.display = 'none';
            } else {
                if (recsLink) recsLink.style.display = 'none';
                if (logoutLink) logoutLink.style.display = 'none';
                if (loginLink) loginLink.style.display = 'inline-block';
            }
        });

        function logout() {
            localStorage.removeItem('travlr-token');
            localStorage.removeItem('travlr-user');
            window.location.assign('/');
        }

        async function loadRecommendations() {
            const token = localStorage.getItem('travlr-token');
            const list = document.getElementById('recs-list');

            if (!token) {
                list.innerHTML = '<p>Please <a href="/login">login</a> to see recommendations.</p>';
                return;
            }

            try {
                const response = await fetch('/api/recommendations', {
                    headers: { 'Authorization': `Bearer ${token}` }
                });

                if (response.status === 401) {
                    list.innerHTML = '<p>Session expired. Please <a href="/login">login again</a>.</p>';
                    return;
                }

                const trips = await response.json();
                list.innerHTML = '';

                if (trips.length === 0) {
                    list.innerHTML = '<p>No matches found. Try updating your profile!</p>';
                    return;
                }

                trips.forEach(trip => {
                    const highlight = (field) => trip.matches.includes(field)
                        ? 'style="background-color: #c8e6c9; font-weight: bold;"'
                        : '';

                    const startDate = new Date(trip.start).toLocaleDateString('en-US', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric'
                    });

                    const item = `
                        <div class="recommendation-item">
                            <table style="border-collapse: collapse;">
                                <tr>
                                    <td style="vertical-align: top; padding-right: 20px; width: 220px;">
                                        <div style="width: 220px;">
                                            <a href="/api/trips/${trip.code}">
                                                <img src="/images/${trip.image}" alt="${trip.name}" width="220" style="display: block;">
                                            </a>
                                            <button onclick="bookTrip('${trip._id}', '${new Date(trip.start).toISOString().split('T')[0]}')">Book Trip</button>
                                        </div>
                                    </td>
                                    <td style="vertical-align: top;">
                                        <h2 style="margin: 0 0 8px 0;"><a href="/travel">${trip.name}</a></h2>
                                        <p>${trip.description}</p>
                                        <table>
                                            <tr><td><strong>Resort</strong></td>    <td>${trip.resort}</td></tr>
                                            <tr><td><strong>Start Date</strong></td><td>${startDate}</td></tr>
                                            <tr><td><strong>Length</strong></td>    <td>${trip.lengthInDays} days</td></tr>
                                            <tr><td><strong>Price</strong></td>     <td>$${trip.price} per person</td></tr>
                                            <tr ${highlight('climate')}><td><strong>Climate</strong></td>       <td>${trip.tags?.climate ?? ''}</td></tr>
                                            <tr ${highlight('activityType')}><td><strong>Activity</strong></td> <td>${trip.tags?.activityType ?? ''}</td></tr>
                                            <tr ${highlight('budgetRange')}><td><strong>Budget</strong></td>    <td>${trip.tags?.budgetRange ?? ''}</td></tr>
                                            <tr ${highlight('tripDuration')}><td><strong>Duration</strong></td> <td>${trip.tags?.tripDuration ?? ''}</td></tr>
                                        </table>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    `;
                    list.innerHTML += item;
                });
            } catch (err) {
                list.innerHTML = '<p>Error loading recommendations.</p>';
            }
        }

        function bookTrip(tripId, travelDate) {
            const token = localStorage.getItem('travlr-token');

            if (!token) {
                alert('You must be logged in to book a trip.');
                return;
            }

            fetch('/api/bookings', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${token}`
                },
                body: JSON.stringify({ tripId, travelDate })
            })
                .then(res => res.json())
                .then(data => {
                    if (data._id) {
                        alert('Booking confirmed!');
                    } else {
                        alert(data.message || 'Booking failed.');
                    }
                })
                .catch(err => {
                    console.error(err);
                    alert('Something went wrong. Please try again.');
                });
        }

        document.addEventListener('DOMContentLoaded', loadRecommendations);
    </script>
</body>

</html>